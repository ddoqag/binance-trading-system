# 币安量化交易系统 - 实盘配置
# ⚠️ 注意：这是实盘配置，使用真实资金

# ============================================
# 运行模式
# ============================================
MODE=live
CONFIRM_LIVE_TRADING=YES
SYMBOL=BTCUSDT

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=binance
DB_USER=postgres
DB_PASSWORD=362232

# ============================================
# 交易配置
# ============================================
INITIAL_CAPITAL=
MAX_POSITION_SIZE=0.3
MAX_SINGLE_POSITION=0.2
PAPER_TRADING=false
USE_LEVERAGE=true
COMMISSION_RATE=0.001
DEFAULT_SYMBOL=BTCUSDT
DEFAULT_INTERVAL=1h

# ============================================
# WebSocket Trading (WS-API v3)
# ============================================
trading.ws-api.enabled=true

# ============================================
# 币安 API 配置（实盘 - 真实资金）

# 币安量化交易系统 - 环境变量配置模板
# 复制此文件为 .env 并填入实际配置
# 注意：.env 文件已在 .gitignore 中，不会提交到代码仓库

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=binance
DB_USER=postgres
DB_PASSWORD=your_password_here

# ============================================
# 交易配置
# ============================================
INITIAL_CAPITAL=10000
MAX_POSITION_SIZE=0.8
MAX_SINGLE_POSITION=0.2
PAPER_TRADING=true
COMMISSION_RATE=0.001
DEFAULT_SYMBOL=BTCUSDT
DEFAULT_INTERVAL=1h

# ============================================
# 杠杆交易配置
# ============================================
MAX_LEVERAGE=10.0
MAINTENANCE_MARGIN_RATE=0.005
LEVERAGE_ENABLED=true

# ============================================
# 币安 API 配置
# ============================================
# 测试网密钥（推荐用于开发/测试，虚拟资金无风险）：
#   1. 访问 https://testnet.binance.vision
#   2. 用 GitHub 账号登录
#   3. 点击 "Generate HMAC-SHA-256 Key" 生成密钥
#   4. 同时设置 USE_TESTNET=true
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
USE_TESTNET=true

# ============================================
# 代理配置（中国大陆访问币安 API 需要，不需要则留空）
# ============================================
HTTPS_PROXY=http://127.0.0.1:7897
HTTP_PROXY=http://127.0.0.1:7897

# ============================================
# Redis 配置
# ============================================
# Redis 服务器地址 (WSL2 使用 192.168.18.62，本机使用 localhost)
REDIS_HOST=192.168.18.62
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# trading_system Phase 1
# ============================================
TRADING_MODE=paper
TRADING_SYMBOL=BTCUSDT
TRADING_INTERVAL=1h
INITIAL_BALANCE=10000
KIMI_API_KEY=
